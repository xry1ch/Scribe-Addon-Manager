{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scribe Addon Manager",
  "version": "0.1.0",
  "identifier": "dev.scribe.addon-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Scribe Addon Manager",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
