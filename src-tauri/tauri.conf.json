{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scribe Addon Manager",
  "version": "1.0.0",
  "identifier": "dev.scribe.addon-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scribe Addon Manager",
        "width": 1360,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#0b1120",
        "devtools": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
