{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Scribe Addon Manager main window.",
  "remote": {
    "urls": ["http://localhost:1420", "http://localhost:1420/*", "http://127.0.0.1:1420", "http://127.0.0.1:1420/*"]
  },
  "windows": ["main"],
  "permissions": [
    "dialog:allow-open",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:webview:allow-internal-toggle-devtools"
  ]
}
